# ==============================
# Apex 环境变量配置模板
# 复制本文件为 .env 并填入实际值
# ==============================

# 应用基础
DEBUG=false
ENVIRONMENT=production

# JWT（生产环境请替换为随机强密钥）
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRE_MINUTES=1440

# 飞书应用
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=https://your-domain.com/api/auth/feishu/callback

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=apex
MYSQL_PASSWORD=apex_password
MYSQL_DATABASE=apex
MYSQL_ROOT_PASSWORD=root_password

# 数据路径（Docker 容器内路径）
DATA_DIR=/data
PARQUET_DIR=/parquet

# 定时同步（每日 05:10）
SYNC_HOUR=5
SYNC_MINUTE=10

# 阿里云 OSS（数据同步源）
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_PREFIX=
