# ==============================
# Apex 后端通用环境变量模板
# 建议：
#   本地开发：复制为 .env.local
#   线上部署：复制为 .env.production，并设置 APEX_ENV_FILE 指向它
# ==============================

# 应用基础
DEBUG=false
ENVIRONMENT=production

# JWT（生产环境必须替换为强随机密钥）
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRE_MINUTES=1440

# 飞书应用
FEISHU_APP_ID=cli_a9411ce5aaf89cb0
FEISHU_APP_SECRET=replace-with-your-feishu-secret
# 外部浏览器 OAuth 回调地址，需在飞书开放平台「安全设置 > 重定向 URL」中添加白名单
# 格式：https://your-domain.com/api/auth/feishu/callback
FEISHU_REDIRECT_URI=https://your-domain.com/api/auth/feishu/callback

# 前端地址（站点域名）
FRONTEND_URL=https://your-domain.com

# Redis（本机部署可填 redis://127.0.0.1:6379/0）
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# MySQL（本机部署可填 127.0.0.1）
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=apex
MYSQL_PASSWORD=
MYSQL_DATABASE=apex
MYSQL_ROOT_PASSWORD=

# 数据路径
# DATA_DIR: 运行期数据根目录，同步后各版本存放在 DATA_DIR/raw/<YYYYMMDD>/
#           软链 DATA_DIR/parquet_current 指向当前版本，DuckDB 优先使用软链
# PARQUET_DIR: 本地开发回退路径（无软链时使用），填写 backend/parquet 绝对路径
DATA_DIR=/data
PARQUET_DIR=/absolute/path/to/backend/parquet

# 定时同步（每日 05:10）
SYNC_HOUR=5
SYNC_MINUTE=10

# 阿里云 OSS
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=apex-oss
OSS_PREFIX=
