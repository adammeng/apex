# ==============================
# Apex 后端本地开发环境变量模板
# 复制为 .env.local 并填入实际值
# 启动优先级：.env -> .env.local（.env.local 覆盖同名项）
# ==============================

# 应用基础
DEBUG=true
ENVIRONMENT=development

# JWT（本地可用测试值，线上必须替换）
JWT_SECRET=dev-only-secret-change-in-production
JWT_EXPIRE_MINUTES=1440

# 飞书应用
FEISHU_APP_ID=cli_a9411ce5aaf89cb0
FEISHU_APP_SECRET=replace-with-your-feishu-secret
FEISHU_REDIRECT_URI=https://apex.adammeng.xyz/

# 前端地址（本地开发）
FRONTEND_URL=http://localhost:5173

# Redis（本地 Homebrew）
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# MySQL（本地 Homebrew）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=apex
MYSQL_PASSWORD=
MYSQL_DATABASE=apex
MYSQL_ROOT_PASSWORD=

# 数据路径
DATA_DIR=/data
PARQUET_DIR=/absolute/path/to/backend/parquet

# 定时同步（每日 05:10）
SYNC_HOUR=5
SYNC_MINUTE=10

# 阿里云 OSS
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=apex-oss
OSS_PREFIX=
