# ==============================
# Apex 后端线上部署环境变量模板
# 复制为 .env.production，启动时设置：
#   export APEX_ENV_FILE=/opt/apex/backend/.env.production
# ==============================

# 应用基础
DEBUG=false
ENVIRONMENT=production

# JWT（生产环境必须替换为强随机密钥）
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRE_MINUTES=1440

# 飞书应用
FEISHU_APP_ID=cli_a9411ce5aaf89cb0
FEISHU_APP_SECRET=replace-with-your-feishu-secret
FEISHU_REDIRECT_URI=https://8-217-230-153.sslip.io/api/auth/feishu/launch

# 前端地址（线上站点）
FRONTEND_URL=https://8-217-230-153.sslip.io

# Redis（Docker Compose 服务名）
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# MySQL（Docker Compose 服务名）
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=apex
MYSQL_PASSWORD=replace-with-your-mysql-password
MYSQL_DATABASE=apex
MYSQL_ROOT_PASSWORD=

# 数据路径
DATA_DIR=/data
PARQUET_DIR=/opt/apex/backend/parquet

# 定时同步（每日 05:10）
SYNC_HOUR=5
SYNC_MINUTE=10

# 阿里云 OSS
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=apex-oss
OSS_PREFIX=
